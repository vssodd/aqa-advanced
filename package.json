{
  "name": "qauto-registration-tests",
  "version": "1.0.0",
  "description": "Cypress E2E tests for registration & login on qauto.forstudy.space",
  "devDependencies": {
    "cypress": "^15.14.2"
  },
  "scripts": {
    "cy:open": "cypress open",
    "cy:run": "cypress run",
    "cy:run:registration": "cypress run --spec cypress/e2e/registration.cy.js",
    "cy:run:login": "cypress run --spec cypress/e2e/login.cy.js",
    "cy:run:masking": "cypress run --spec cypress/e2e/password-masking.cy.js"
  }
}
