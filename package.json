{
  "name": "qauto-dz25-firefox-docker",
  "version": "1.0.0",
  "description": "HW 30.1: Cypress 12 (older version) running in Firefox inside Docker",
  "scripts": {
    "cy:run:firefox": "cypress run --browser firefox",
    "cy:run:chrome": "cypress run --browser chrome",
    "cy:open": "cypress open",
    "docker:firefox": "docker run --rm -v \"%cd%\":/e2e -w /e2e cypress/included:12.17.4 --browser firefox",
    "docker:firefox:bash": "docker run --rm -v $PWD:/e2e -w /e2e cypress/included:12.17.4 --browser firefox"
  },
  "devDependencies": {
    "cypress": "12.17.4"
  }
}
